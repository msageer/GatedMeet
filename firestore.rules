rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /{path=**}/payouts/{payoutId} {
      allow read: if isAdmin();
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return (isSignedIn() && request.auth.token.email == 'msagirgroup@gmail.com') ||
             (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Enterprise Grade User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['creator', 'admin'] &&
             data.createdAt == request.time &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             (data.get('platformFeeTier', 10) >= 5 && data.get('platformFeeTier', 10) <= 20) &&
             (data.get('referralCode', '') is string) &&
             (data.get('referredBy', '') is string) &&
             (data.get('referralCount', 0) >= 0) &&
             (data.get('referralBonuses', 0) >= 0);
    }

    match /users/{userId} {
      // Restrict read access to sensitive data
      allow get: if true; 
      allow list: if true; // Allowed list for referrals
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      
      allow update: if (isSignedIn() && isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'pricing', 'availability', 'walletAddress', 'meetingUrl', 'setupComplete', 'updatedAt', 'referralCode']) &&
        incoming().role == existing().role
      )) || 
      (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['referralCount', 'referralBonuses'])) || 
      isAdmin();

      allow delete: if isAdmin();

      match /payouts/{payoutId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['amount', 'status', 'timestamp']) &&
                      incoming().amount is number && incoming().amount > 0 &&
                      incoming().status == 'pending' &&
                      incoming().timestamp == request.time;
        allow update: if isAdmin(); // only admin can approve/reject
      }
    }

    // --- Booking Validation ---
    function isValidBooking(data) {
      return data.keys().hasAll(['creatorId', 'clientEmail', 'startTime', 'endTime', 'status', 'createdAt']) &&
             isValidId(data.creatorId) &&
             data.clientEmail is string && data.clientEmail.size() <= 256 &&
             data.status in ['pending', 'paid', 'confirmed', 'cancelled'] &&
             data.createdAt == request.time &&
             (data.get('amount', 0) is number && data.get('amount', 0) >= 0);
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (isOwner(existing().creatorId) || existing().clientEmail == request.auth.token.email || isAdmin());
      allow list: if true; // Allowed list for finding unavailable slots and dashboard queries
      
      allow create: if isValidBooking(incoming());
      
      allow update: if (isSignedIn() && (
        (isOwner(existing().creatorId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'meetingLink'])) ||
        isAdmin() ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'transactionId']) && existing().status == 'pending' && incoming().status == 'paid')
      ));
    }

    // --- Transaction Validation ---
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && incoming().type == 'payment'); // Systems or verified payments
    }

    // --- Feedback Validation ---
    match /feedbacks/{feedbackId} {
      // Anyone can read, but typically just creator and admin. Or public on booking page.
      allow read: if true;
      allow create: if incoming().keys().hasAll(['creatorId', 'bookingId', 'rating', 'timestamp']) &&
                    incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5 &&
                    isValidId(incoming().creatorId) && isValidId(incoming().bookingId) &&
                    incoming().timestamp == request.time &&
                    exists(/databases/$(database)/documents/bookings/$(incoming().bookingId));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
